# Copia in .env (non versionato) e compila i valori.
# Decisioni di design applicate: D1 Wikidata-only · D2 scraper standalone · D4 SQLite anche in prod.

# Database (single-file SQLite, anche in produzione — D4)
DATABASE_URL=sqlite:///./cineposto.db

# Percorso ai JSON prodotti dallo scraper (letti dal seed e dall'endpoint reimport)
SCRAPER_OUTPUT_DIR=../scraper/output

# CORS (frontend allowed origins) — formato JSON array obbligatorio
CORS_ORIGINS=["http://localhost:8081","http://localhost:19006","http://localhost:8000"]

# App env
ENV=development
LOG_LEVEL=INFO

# Token segreto per l'endpoint admin di reimport (POST /api/v1/admin/reimport)
# Genera con: python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
# ⚠️  Se lasci vuoto o "change-me-before-deploy", il backend genera un token random
#     al boot e lo stampa nei log. Utile in dev locale.
ADMIN_TOKEN=
